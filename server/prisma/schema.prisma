generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int    @id @default(autoincrement())
  name          String
  email         String @unique
  password      String
  role_id       Int
  phone         String
  department_id Int
  created_at    DateTime @default(now())
  role          Role       @relation(fields: [role_id], references: [id])
  department    Department @relation(fields: [department_id], references: [id])

  @@map("users")
}

model Role {
  id    Int    @id @default(autoincrement())
  role  String
  name  String
  users User[]

  @@map("roles")
}

model Department {
  id    Int    @id @default(autoincrement())
  name  String
  users User[]

  @@map("departments")
}